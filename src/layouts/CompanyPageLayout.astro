---
// CompanyPageLayout — wraps BaseLayout. Used by the sales-interview-prep
// content collection via the dynamic route at
//   src/pages/sales-interview-prep/[company]/[role].astro
//
// Architecture:
//  - All structured data (questions, process, compensation, faqs,
//    culturalClaims) lives in MDX frontmatter. This layout renders each
//    section programmatically from those props.
//  - MDX body holds only the hero lede prose. The route renders <Content />
//    inside our default <slot />, which we place inside slot-hero so the
//    lede appears under the H1.
//  - This pattern was chosen because top-level <Fragment slot="..."> blocks
//    in MDX body do NOT propagate as named slots to a grandparent layout
//    when rendered via <Content />. Verified empirically.
//
// Brand chrome (nav, hero pitch, GA4, UTM cookies, footer CTA, Inter font,
// color tokens) lives entirely in BaseLayout. This file owns only the
// company-page section structure plus extra JSON-LD.

import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const {
  title,
  description,
  canonical,
  ogImage,
  publishDate,
  lastUpdated,
  company,
  companyDisplay,
  role,
  roleDisplay,
  questions = [],
  process = [],
  compensation,
  faqs = [],
  culturalClaims = [],
  ctaCopy,
  diagramSvg,
  screenshotPath,
  screenshotAlt,
} = frontmatter ?? {};

const slugForUtm = company && role ? `${company}-${role}` : undefined;
const baseSite = Astro.site ?? new URL('https://learn.noruma.ai');
const canonicalUrl = canonical || new URL(Astro.url.pathname, baseSite).toString();

const toIso = (d) => (d instanceof Date ? d.toISOString() : new Date(d).toISOString());
const toIsoDate = (d) => toIso(d).slice(0, 10);

// Sort questions by askedTimes desc, then sourceDate desc.
const sortedQuestions = [...questions].sort((a, b) => {
  const ax = a.askedTimes ?? 0;
  const bx = b.askedTimes ?? 0;
  if (bx !== ax) return bx - ax;
  return (b.sourceDate ?? '').localeCompare(a.sourceDate ?? '');
});

const fmtMoney = (n, currency = 'USD') => {
  if (currency !== 'USD') return `${n.toLocaleString()} ${currency}`;
  if (n >= 1_000_000) {
    const v = n / 1_000_000;
    return `$${(v % 1 === 0 ? v.toFixed(0) : v.toFixed(1))}M`;
  }
  if (n >= 1_000) return `$${Math.round(n / 1_000)}k`;
  return `$${n}`;
};
const range = (lo, hi, currency) => `${fmtMoney(lo, currency)}\u2013${fmtMoney(hi, currency)}`;

const ctaUrl = `https://noruma.ai/?noruma_utm_source=learn&noruma_utm_medium=organic&noruma_utm_campaign=${slugForUtm ?? 'index'}`;

// Find a representative process source URL.
const processSource = process.find((r) => r.sourceUrl);

// Extra JSON-LD beyond the Article block BaseLayout already emits.
const faqJsonLd = sortedQuestions.length
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: sortedQuestions.map((q) => ({
        '@type': 'Question',
        name: q.question,
        acceptedAnswer: {
          '@type': 'Answer',
          text: q.sourceQuote ?? `Sourced from ${q.sourceType} (${q.sourceUrl}).`,
        },
      })),
    }
  : null;

const breadcrumbJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Sales Interview Prep',
      item: new URL('/sales-interview-prep/', baseSite).toString(),
    },
    company && companyDisplay
      ? {
          '@type': 'ListItem',
          position: 2,
          name: companyDisplay,
          item: new URL(`/sales-interview-prep/${company}/`, baseSite).toString(),
        }
      : null,
    roleDisplay
      ? { '@type': 'ListItem', position: 3, name: roleDisplay, item: canonicalUrl }
      : null,
  ].filter(Boolean),
};

const orgJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Noruma',
  url: 'https://noruma.ai',
  description: 'Real-time AI interview copilot for tech sales professionals.',
};
---
<BaseLayout
  title={title}
  description={description}
  canonical={canonicalUrl}
  ogImage={ogImage}
  schemaType="Article"
  publishDate={publishDate}
  slug={slugForUtm}
>
  <div class="company-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/sales-interview-prep/">Sales Interview Prep</a>
      {companyDisplay && <span aria-hidden="true"> / </span>}
      {companyDisplay && <span>{companyDisplay}</span>}
      {roleDisplay && <span aria-hidden="true"> / </span>}
      {roleDisplay && <span>{roleDisplay}</span>}
    </nav>

    <section class="slot slot-hero">
      <slot />
      {lastUpdated && (
        <p class="last-updated">Last updated {toIsoDate(lastUpdated)}</p>
      )}
    </section>

    {process.length > 0 && (
      <section class="slot slot-process">
        <h2>Interview process</h2>
        <table>
          <thead>
            <tr>
              <th>Round</th>
              <th>Format</th>
              <th>Duration</th>
              <th>Who you meet</th>
              <th>Focus</th>
            </tr>
          </thead>
          <tbody>
            {process.map((r) => (
              <tr>
                <td>{r.round}</td>
                <td>{r.format}{r.name ? ` (${r.name})` : ''}</td>
                <td>{r.durationMin ? `${r.durationMin} min` : ''}</td>
                <td>{r.who ?? ''}</td>
                <td>{r.focus ?? ''}</td>
              </tr>
            ))}
          </tbody>
        </table>
        {processSource && (
          <p class="cite">
            Process sourced from <a href={processSource.sourceUrl}>{processSource.sourceType ?? 'public posting'}</a>.
          </p>
        )}
        {diagramSvg && (
          <figure class="diagram">
            <img src={diagramSvg} alt={`${companyDisplay} ${roleDisplay} interview funnel diagram`} width="800" height="320" loading="lazy" />
          </figure>
        )}
      </section>
    )}

    {sortedQuestions.length > 0 && (
      <section class="slot slot-questions">
        <h2>Questions and sources</h2>
        <ol class="questions">
          {sortedQuestions.map((q) => (
            <li>
              <strong>{q.question}</strong>{' '}
              Sourced from <a href={q.sourceUrl}>{q.sourceType}</a>
              {q.sourceDate ? ` (${q.sourceDate})` : ''}.
              {q.sourceQuote && (
                <blockquote>{q.sourceQuote}</blockquote>
              )}
            </li>
          ))}
        </ol>
      </section>
    )}

    {compensation && (
      <section class="slot slot-comp">
        <h2>Compensation benchmarks</h2>
        <table>
          <thead>
            <tr><th>Metric</th><th>Range</th></tr>
          </thead>
          <tbody>
            <tr><td>Base</td><td>{range(compensation.baseMin, compensation.baseMax, compensation.currency)}</td></tr>
            <tr><td>OTE</td><td>{range(compensation.oteMin, compensation.oteMax, compensation.currency)}</td></tr>
            <tr><td>Quota</td><td>{range(compensation.quotaMin, compensation.quotaMax, compensation.currency)}</td></tr>
          </tbody>
        </table>
        <p class="cite">
          Source: <a href={compensation.sourceUrl}>{compensation.source}</a>, as of {compensation.asOfDate}, sample size {compensation.sampleSize} reps.
        </p>
      </section>
    )}

    {culturalClaims.length > 0 && (
      <section class="slot slot-claims">
        <h2>What candidates report</h2>
        <ul class="claims">
          {culturalClaims.map((c) => (
            <li>
              {c.claim}. (<a href={c.sourceUrl}>{c.sourceLabel}</a>)
            </li>
          ))}
        </ul>
      </section>
    )}

    {faqs.length > 0 && (
      <section class="slot slot-faq">
        <h2>FAQ</h2>
        {faqs.map((f) => (
          <article class="faq-item">
            <h3>{f.q}</h3>
            <p>
              {f.a}
              {f.sourceUrl && <> (Source: <a href={f.sourceUrl}>link</a>)</>}
            </p>
          </article>
        ))}
      </section>
    )}

    <section class="slot slot-cta">
      <p>
        {ctaCopy ?? `Practice these questions live with `}
        <a href={ctaUrl}>Noruma's real-time interview copilot</a>.
        Audio is processed in real time and not retained unless you opt in.
      </p>
    </section>
  </div>

  {faqJsonLd && (
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  )}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
</BaseLayout>

<style>
  .company-page {
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .crumbs {
    font-size: 13px;
    color: var(--text-tertiary, #9CA5B2);
    margin-bottom: 8px;
  }
  .crumbs a {
    color: var(--text-tertiary, #9CA5B2);
    text-decoration: none;
  }
  .crumbs a:hover {
    color: var(--accent, #00E0CC);
  }
  .slot {
    padding: 32px 0;
    border-bottom: 1px solid var(--border, rgba(255, 255, 255, 0.08));
  }
  .slot:last-of-type {
    border-bottom: none;
  }
  .slot h2 {
    color: var(--accent, #00E0CC);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -0.01em;
    margin: 0 0 18px;
  }
  .slot-hero { padding-top: 0; }
  .last-updated {
    color: var(--text-tertiary, #9CA5B2);
    font-size: 13px;
    margin: 16px 0 0;
  }
  table {
    border-collapse: collapse;
    width: 100%;
    font-size: 0.95rem;
    margin: 0 0 8px;
  }
  th, td {
    border-bottom: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    padding: 0.625rem 0.75rem;
    text-align: left;
    color: var(--text-secondary, #C5CCD6);
  }
  th {
    color: var(--text-tertiary, #9CA5B2);
    font-weight: 500;
    font-size: 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .cite {
    font-size: 13px;
    color: var(--text-tertiary, #9CA5B2);
    margin: 8px 0 0;
  }
  .diagram {
    margin: 24px 0 0;
  }
  .diagram img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid var(--border, rgba(255, 255, 255, 0.08));
    background: var(--surface-1, #111318);
  }
  .questions {
    padding-left: 22px;
  }
  .questions li {
    margin: 14px 0;
    color: var(--text-secondary, #C5CCD6);
  }
  .questions li strong {
    color: var(--text, #F7F8FB);
    font-weight: 600;
  }
  .questions blockquote {
    margin: 8px 0 0;
    padding: 8px 14px;
    border-left: 2px solid var(--accent, #00E0CC);
    background: var(--surface-1, #111318);
    color: var(--text-secondary, #C5CCD6);
    font-size: 0.95em;
    border-radius: 4px;
  }
  .claims {
    padding-left: 22px;
    color: var(--text-secondary, #C5CCD6);
  }
  .claims li { margin: 8px 0; }
  .faq-item { margin: 0 0 24px; }
  .faq-item h3 {
    font-size: 17px;
    font-weight: 600;
    margin: 0 0 6px;
    color: var(--text, #F7F8FB);
  }
  .faq-item p {
    margin: 0;
    color: var(--text-secondary, #C5CCD6);
  }
  .slot-cta {
    background: linear-gradient(180deg, rgba(0, 224, 204, 0.08), rgba(0, 224, 204, 0.02));
    border: 1px solid rgba(0, 224, 204, 0.25);
    border-radius: 12px;
    padding: 24px 28px;
    margin: 32px 0 0;
  }
  .slot-cta p {
    margin: 0;
    color: var(--text-secondary, #C5CCD6);
  }
</style>
