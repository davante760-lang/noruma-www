---
// SalaryPageLayout — companion to CompanyPageLayout. Comp-focused page.
// Higher commercial intent than the prep page; cross-links to the prep
// page's sibling slug.

import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const {
  title, description, canonical, ogImage, publishDate, lastUpdated,
  company, companyDisplay, role, roleDisplay,
  compensation, redditQuotes = [], peerCompanies = [], faqs = [],
} = frontmatter ?? {};

const slugForUtm = company && role ? `salary-${company}-${role}` : undefined;
const baseSite = Astro.site ?? new URL('https://learn.noruma.ai');
const canonicalUrl = canonical || new URL(Astro.url.pathname, baseSite).toString();
const prepUrl = `/sales-interview-prep/${company}/${role}`;
const ctaUrl = `https://noruma.ai/?noruma_utm_source=learn&noruma_utm_medium=organic&noruma_utm_campaign=${slugForUtm ?? 'index'}`;

const fmtMoney = (n, currency = 'USD') => {
  if (n == null) return '';
  if (currency !== 'USD') return `${n.toLocaleString()} ${currency}`;
  if (n >= 1_000_000) { const v = n / 1_000_000; return `$${v % 1 === 0 ? v.toFixed(0) : v.toFixed(1)}M`; }
  if (n >= 1_000) return `$${Math.round(n / 1_000)}k`;
  return `$${n}`;
};
const range = (lo, hi, c) => `${fmtMoney(lo, c)}\u2013${fmtMoney(hi, c)}`;
const toIsoDate = (d) => (d instanceof Date ? d.toISOString() : new Date(d).toISOString()).slice(0, 10);

const articleJsonLd = {
  '@context': 'https://schema.org', '@type': 'Article',
  headline: title, description,
  datePublished: publishDate ? new Date(publishDate).toISOString() : undefined,
  dateModified: lastUpdated ? new Date(lastUpdated).toISOString() : undefined,
  about: { '@type': 'Organization', name: companyDisplay },
  url: canonicalUrl,
};
const breadcrumbJsonLd = {
  '@context': 'https://schema.org', '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Salaries', item: new URL('/salaries/', baseSite).toString() },
    { '@type': 'ListItem', position: 2, name: companyDisplay, item: new URL(`/salaries/${company}/`, baseSite).toString() },
    { '@type': 'ListItem', position: 3, name: roleDisplay, item: canonicalUrl },
  ],
};
const faqJsonLd = faqs.length ? {
  '@context': 'https://schema.org', '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })),
} : null;
const orgJsonLd = {
  '@context': 'https://schema.org', '@type': 'Organization',
  name: 'Noruma', url: 'https://noruma.ai',
  description: 'Real-time AI copilot for live sales interviews.',
};
---
<BaseLayout title={title} description={description} canonical={canonicalUrl} ogImage={ogImage} schemaType="Article" publishDate={publishDate} slug={slugForUtm}>
  <div class="salary-page">
    <nav class="crumbs" aria-label="Breadcrumb">
      <a href="/salaries/">Salaries</a> / <span>{companyDisplay}</span> / <span>{roleDisplay}</span>
    </nav>

    <section class="slot slot-hero">
      <slot />
      {lastUpdated && <p class="last-updated">Last updated {toIsoDate(lastUpdated)}</p>}
    </section>

    {compensation && (
      <section class="slot">
        <h2>{companyDisplay} {roleDisplay} compensation</h2>
        <table>
          <thead><tr><th>Metric</th><th>p25</th><th>Median</th><th>p75</th></tr></thead>
          <tbody>
            <tr>
              <td>Base salary</td>
              <td>{fmtMoney(compensation.baseMin)}</td>
              <td>{fmtMoney(Math.round((compensation.baseMin + compensation.baseMax) / 2))}</td>
              <td>{fmtMoney(compensation.baseMax)}</td>
            </tr>
            {compensation.oteMin && compensation.oteMax && (
              <tr>
                <td>OTE</td>
                <td>{fmtMoney(compensation.oteMin)}</td>
                <td>{fmtMoney(Math.round((compensation.oteMin + compensation.oteMax) / 2))}</td>
                <td>{fmtMoney(compensation.oteMax)}</td>
              </tr>
            )}
          </tbody>
        </table>
        <p class="cite">
          Source: <a href={compensation.sourceUrl}>{compensation.source}</a>, as of {compensation.asOfDate}, sample size {compensation.sampleSize} reps.
        </p>
      </section>
    )}

    <aside class="cta-aside">
      <h3>Negotiating an offer? Noruma populates the perfect comp answer in real time.</h3>
      <p>When the recruiter asks your number, Noruma surfaces the right framing live, anchored to the public band. No fumbling the math.</p>
      <a href={ctaUrl}>Try Noruma free &rarr;</a>
    </aside>

    {peerCompanies.length > 0 && (
      <section class="slot">
        <h2>How {companyDisplay} comp compares to peers</h2>
        <table>
          <thead><tr><th>Company</th><th>Base range</th><th>OTE range</th></tr></thead>
          <tbody>
            {peerCompanies.map(p => (
              <tr>
                <td><a href={`/salaries/${p.company}/${role}`}>{p.companyDisplay}</a></td>
                <td>{range(p.baseMin, p.baseMax)}</td>
                <td>{p.oteMin && p.oteMax ? range(p.oteMin, p.oteMax) : '—'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>
    )}

    {redditQuotes.length > 0 && (
      <section class="slot">
        <h2>What r/sales says about {companyDisplay} comp</h2>
        {redditQuotes.map(q => (
          <blockquote class="reddit-quote">
            <p>{q.quote}</p>
            <footer><a href={q.sourceUrl}>r/sales{q.sourceDate ? ` · ${q.sourceDate}` : ''}</a></footer>
          </blockquote>
        ))}
      </section>
    )}

    <section class="slot related-prep">
      <h2>Prepping for the {companyDisplay} {roleDisplay} interview?</h2>
      <p>Read the full interview prep guide: <a href={prepUrl}>{companyDisplay} {roleDisplay} interview prep</a> — process, questions, and how to walk in ready.</p>
    </section>

    {faqs.length > 0 && (
      <section class="slot">
        <h2>FAQ</h2>
        {faqs.map(f => (
          <article class="faq-item">
            <h3>{f.q}</h3>
            <p>{f.a}{f.sourceUrl && <> (Source: <a href={f.sourceUrl}>link</a>)</>}</p>
          </article>
        ))}
      </section>
    )}

    <section class="slot slot-cta">
      <p>
        This page is the comp benchmark. When you're in the live {companyDisplay} {roleDisplay} interview, <a href={ctaUrl}>Noruma populates the perfect answer for every question in real time</a>, drawn from your prep and your own deal stories. Audio is processed in real time and not retained unless you opt in.
      </p>
    </section>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(articleJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />
  {faqJsonLd && <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />}
  <script type="application/ld+json" set:html={JSON.stringify(orgJsonLd)} />
</BaseLayout>

<style>
  .salary-page { display: flex; flex-direction: column; }
  .crumbs { font-size: 13px; color: var(--text-tertiary, #9CA5B2); margin-bottom: 8px; }
  .crumbs a { color: var(--text-tertiary, #9CA5B2); text-decoration: none; }
  .crumbs a:hover { color: var(--accent, #00E0CC); }
  .slot { padding: 32px 0; border-bottom: 1px solid var(--border, rgba(255,255,255,0.08)); }
  .slot:last-of-type { border-bottom: none; }
  .slot h2 { color: var(--accent, #00E0CC); font-size: 22px; font-weight: 600; margin: 0 0 18px; }
  .slot-hero { padding-top: 0; }
  .last-updated { color: var(--text-tertiary, #9CA5B2); font-size: 13px; margin: 16px 0 0; }
  table { border-collapse: collapse; width: 100%; font-size: 0.95rem; margin: 0 0 8px; }
  th, td { border-bottom: 1px solid var(--border, rgba(255,255,255,0.08)); padding: 0.625rem 0.75rem; text-align: left; color: var(--text-secondary, #C5CCD6); }
  th { color: var(--text-tertiary, #9CA5B2); font-weight: 500; font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.05em; }
  .cite { font-size: 13px; color: var(--text-tertiary, #9CA5B2); margin: 8px 0 0; }
  .reddit-quote { margin: 16px 0; padding: 14px 18px; border-left: 2px solid var(--accent, #00E0CC); background: var(--surface-1, #111318); border-radius: 4px; }
  .reddit-quote p { margin: 0 0 8px; color: var(--text-secondary, #C5CCD6); }
  .reddit-quote footer { font-size: 13px; color: var(--text-tertiary, #9CA5B2); }
  .reddit-quote footer a { color: var(--text-tertiary, #9CA5B2); text-decoration: none; }
  .faq-item { margin: 0 0 24px; }
  .faq-item h3 { font-size: 17px; font-weight: 600; margin: 0 0 6px; color: var(--text, #F7F8FB); }
  .faq-item p { margin: 0; color: var(--text-secondary, #C5CCD6); }
  .related-prep p { color: var(--text-secondary, #C5CCD6); }
  .related-prep a { color: var(--accent, #00E0CC); }
  .slot-cta { background: linear-gradient(180deg, rgba(0,224,204,0.08), rgba(0,224,204,0.02)); border: 1px solid rgba(0,224,204,0.25); border-radius: 12px; padding: 24px 28px; margin: 32px 0 0; }
  .slot-cta p { margin: 0; color: var(--text-secondary, #C5CCD6); }
  .cta-aside { background: linear-gradient(90deg, rgba(0,224,204,0.05), rgba(0,224,204,0.01)); border-left: 3px solid var(--accent, #00E0CC); border-radius: 6px; padding: 14px 18px; margin: 12px 0 0; }
  .cta-aside h3 { color: var(--text, #F7F8FB); font-size: 15px; font-weight: 600; margin: 0 0 6px; }
  .cta-aside p { color: var(--text-secondary, #C5CCD6); font-size: 14px; margin: 0 0 8px; }
  .cta-aside a { color: var(--accent, #00E0CC); font-size: 13px; font-weight: 500; text-decoration: none; }
</style>
