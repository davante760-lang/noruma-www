---
import { getCollection, render } from 'astro:content';
import QuestionHubLayout from '../../layouts/QuestionHubLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('interview-questions');
  return entries.map((entry) => ({
    params: { role: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<QuestionHubLayout frontmatter={entry.data}>
  <Content />
</QuestionHubLayout>
